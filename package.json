{
  "name": "gtm-skills",
  "version": "0.27.0",
  "description": "205 production go-to-market playbooks for AI agents across 24 categories. Framework-cited GTM skills for Claude Code, Jesse, Codex, Hermes, Windsurf, OpenCode, Gemini CLI, Copilot, Zed, VS Code, and Goose.",
  "keywords": [
    "abm",
    "agent-skills",
    "agentic-gtm",
    "agentskills",
    "ai-sales",
    "b2b-sales",
    "claude-code",
    "claude-skills",
    "codex",
    "cold-email",
    "jesse",
    "customer-success",
    "deliverability",
    "demand-generation",
    "enrichment",
    "founder",
    "go-to-market",
    "gtm",
    "gtm-playbooks",
    "lead-generation",
    "lifecycle-marketing",
    "marketing",
    "outbound",
    "plg",
    "prospecting",
    "revenue-operations",
    "saas",
    "sales",
    "sales-automation",
    "sales-enablement",
    "startup"
  ],
  "license": "MIT",
  "author": "LeadMagic",
  "repository": {
    "type": "git",
    "url": "https://github.com/LeadMagic/gtm-skills.git"
  },
  "homepage": "https://github.com/LeadMagic/gtm-skills",
  "scripts": {
    "validate": "node scripts/validate-skills.js",
    "generate-indexes": "node scripts/generate-indexes.js",
    "generate-pitfalls": "node scripts/generate-pitfalls-index.js",
    "build": "bash scripts/regenerate.sh",
    "regenerate": "bash scripts/regenerate.sh",
    "check:lock": "python3 scripts/generate-skills-lock.py --check",
    "check:install": "python3 scripts/install-tui.py --target jesse --project /tmp/gtm-skills-install-test --dry-run",
    "check:public": "python3 scripts/public-repo-audit.py",
    "check:references": "python3 scripts/audit-references.py",
    "check:generated": "bash scripts/check-generated.sh",
    "check": "node scripts/validate-skills.js && python3 scripts/audit-references.py && python3 scripts/generate-skills-lock.py --check && python3 scripts/install-tui.py --target jesse --project /tmp/gtm-skills-install-test --dry-run && python3 scripts/public-repo-audit.py",
    "publish:dry-run": "gh skill publish --dry-run",
    "lint": "node scripts/validate-skills.js && python3 scripts/public-repo-audit.py",
    "install:tui": "python3 scripts/install-tui.py",
    "install:dry-run": "python3 scripts/install-tui.py --target all --dry-run",
    "verify": "npm run check && npm run check:generated"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
